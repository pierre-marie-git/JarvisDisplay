<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="false">

    <!-- Accent bar at top -->
    <View
        android:id="@+id/accent_bar"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_gravity="top"
        android:background="#33FF33" />

    <!-- Mute button top-right -->
    <ImageButton
        android:id="@+id/mute_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:background="@android:color/transparent"
        android:contentDescription="Mute"
        android:padding="8dp"
        android:src="@android:drawable/ic_lock_silent_mode_off" />

    <!-- Flip board grid -->
    <com.jarvis.display.FlipBoardView
        android:id="@+id/flip_board"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:padding="4dp" />

    <!-- Status text at bottom -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="4dp"
        android:text="Last refresh: --:--:--"
        android:textColor="#666666"
        android:textSize="10sp"
        android:fontFamily="monospace" />

    <!-- Invisible admin tap zone (bottom-right corner) -->
    <View
        android:id="@+id/admin_tap_zone"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="bottom|end"
        android:background="@android:color/transparent" />

</FrameLayout>
